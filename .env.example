# Fichier .env.example - Copier en .env pour le développement local

# === Configuration Serveur ===
PORT=8080
HOST=0.0.0.0
READ_TIMEOUT=30
WRITE_TIMEOUT=30
SHUTDOWN_TIMEOUT=5

# === Storage Configuration ===
# Options: local, s3, gcs, azure
STORAGE_TYPE=local

# Storage Local (dev)
STORAGE_LOCAL_PATH=./storage

# === S3-Compatible Storage ===
# Fonctionne avec: AWS S3, MinIO, DigitalOcean Spaces, Scaleway, etc.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=facturx
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_USE_PATH_STYLE=true
# S3_FORCE_PATH_STYLE=false

# === Google Cloud Storage ===
# GCS avec S3-compatible API (HMAC keys)
# STORAGE_TYPE=gcs
# S3_ENDPOINT=https://storage.googleapis.com
# S3_BUCKET=your-bucket
# S3_ACCESS_KEY=your-gcs-access-key
# S3_SECRET_KEY=your-gcs-secret-key
# GCS_PROJECT_ID=your-project-id
# GCS_CREDENTIALS_PATH=/path/to/credentials.json

# === Azure Blob Storage ===
# STORAGE_TYPE=azure
# AZURE_ACCOUNT_NAME=your-account
# AZURE_ACCOUNT_KEY=your-key
# AZURE_CONTAINER=facturx

# === Authentication ===
AUTH_ENABLED=true
AUTH_API_KEY=my-secret-api-key-for-backend-calls
AUTH_PASSWORD=my-secure-password-for-ui
# e.g openssl rand -hex 64
AUTH_JWT_SECRET=super-secret-key-change-me-in-production

# === UI & Frontend ===
# Activer l'interface web Angular servie par l'API (production)
WEB_UI_ENABLED=true
# WEB_UI_PATH=./web/ng

# === Feature Flags ===
# Active le mode "template Typst custom" (découplé de Factur-X):
# expose les endpoints /api/v1/custom/* et une page d'édition dédiée dans l'UI.
# L'utilisateur fournit un template Typst + un JSON Schema (validation + mock de preview).
ALLOW_CUSTOM_TEMPLATES=false

# === Templates & Typst ===
TEMPLATES_PATH=./templates-custom
# Dossier contenant des polices d'écritures additionnelles pour Typst
# TYPST_FONT_PATHS=./fonts
# Racine virtuelle pour Typst (permet les chemins absolus /images/logo.png dans les templates)
TYPST_ROOT=.

# === AI Generation ===
# 1. Google Gemini (via OpenAI API compatibility)
AI_PROVIDER=openai
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL=gemini-3.5-flash
AI_API_KEY=your-api-key-here

# 2. DeepSeek (via OpenAI API compatibility)
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-coder-v4pro # ou deepseek-chat
# AI_API_KEY=your-deepseek-key-here

# 3. Ollama (Local)
# L'utilisation de host.docker.internal est souvent nécessaire sous Docker
# AI_PROVIDER=ollama
# AI_BASE_URL=http://host.docker.internal:11434
# AI_MODEL=llama3.2
# AI_API_KEY=not-needed
